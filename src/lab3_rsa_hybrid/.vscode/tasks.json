                "-l:libcrypto.a",
                "-lws2_32",
                "-lcrypt32",
                "-ID:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\include",
                "-Wall"
            ],
            "options": {
                "cwd": "C:\\msys64\\mingw64\\bin"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "Biên dịch file .exe bằng Clang"
