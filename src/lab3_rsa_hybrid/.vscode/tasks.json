        {
            "type": "shell",
            "label": "3. EXE: cl.exe build active file (MSVC)",
            "command": "cl.exe",
            "args": [
                "/std:c++17",
                "/EHsc",
                "/O2",
                "/DNDEBUG",
                "/MTd",
                "/Fe:${fileDirname}\\${fileBasenameNoExtension}msvc.exe",
                "${file}",
                "/I",
                "D:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\include",
                "/link",
                "/LIBPATH:D:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\lib\\cryptopp\\msvc",
                "/LIBPATH:D:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\lib64",
                "cryptlib.lib",
                "libcrypto.lib",
                "ws2_32.lib",
                "crypt32.lib"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "detail": "Biên dịch file .exe bằng MSVC"
        },

        // ==========================================
        // 2. NHÓM TASK BIÊN DỊCH RA THƯ VIỆN (.DLL)
