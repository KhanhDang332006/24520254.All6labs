{
    "version": "2.0.0",
    "tasks": [
        // ==========================================
        // 1. NHÓM TASK BIÊN DỊCH RA FILE THỰC THI (.EXE)
        // ==========================================
        {
            "type": "shell",
            "label": "1. EXE: g++.exe build active file (MinGW)",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-g2",
                "-O3",
                "-DNDEBUG",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}gcc.exe",
                "-D_WIN32_WINNT=0x0602",
                "-lpthread",
                "-LD:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\lib\\cryptopp\\gcc",
                "-LD:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\lib64",
                "-l:libcryptopp.a",
                "-l:libcrypto.a",
                "-lws2_32",
                "-lcrypt32",
                "-ID:\\Tai_lieu\\UIT_Document\\HK2_2025_2026\\NT219_MatMaHoc\\Labs\\CryptoLib\\include",
                "-Wall"
            ],
            "options": {
                "cwd": "C:\\msys64\\mingw64\\bin"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "Biên dịch file .exe bằng MinGW GCC"
        },
        {
            "type": "shell",
            "label": "2. EXE: clang++.exe build active file (Clang)",
            "command": "C:\\msys64\\mingw64\\bin\\clang++.exe",
            "args": [
                "-std=c++17",
                "-O3",
                "-DNDEBUG",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}clang.exe",
                "-D_WIN32_WINNT=0x0602",
